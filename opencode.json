{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md",
    "SPEC.md",
    "docs/GRAMMAR.md",
    "rust/lumen-compiler/AGENTS.md",
    "rust/lumen-rt/AGENTS.md",
    "rust/lumen-cli/AGENTS.md"
  ],
  "permission": {
    "*": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "task": "allow",
    "bash": {
      "*": "allow",
      "git stash*": "deny",
      "git reset*": "deny",
      "git clean*": "deny",
      "git checkout -- *": "deny",
      "git restore*": "deny",
      "git push*": "deny",
      "rm -rf /*": "deny"
    },
    "external_directory": {
      "/tmp/**": "allow",
      "/var/tmp/**": "allow",
      "~/.cache/**": "allow",
      "*": "ask"
    }
  }
}
